#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>

/ {
    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
                &kp ESC   &kp N1   &kp N2   &kp N3    &kp N4    &kp N5        &kp N6    &kp N7    &kp N8    &kp N9   &kp N0   &kp BSPC
                &kp TAB   &kp Q    &kp W    &kp E     &kp R     &kp T         &kp Y     &kp U     &kp I     &kp O    &kp P    &kp BSLH
                &kp CLCK  &kp A    &kp S    &kp D     &kp F     &kp G         &kp H     &kp J     &kp K     &kp L    &kp SEMI &kp SQT
                &kp LSHFT &kp Z    &kp X    &kp C     &kp V     &kp B         &kp N     &kp M     &kp COMMA &kp DOT  &kp FSLH &kp RET
                &kp LCTRL &kp LGUI &kp LALT &mo 1     &kp SPACE &kp SPACE     &kp SPACE &kp SPACE &mo 1     &kp RALT &kp RGUI &kp RCTRL
            >;
        };

        function_layer {
            bindings = <
                &bt BT_CLR &bt BT_SEL 0 &bt BT_SEL 1 &bt BT_SEL 2 &none &none    &none &none &none &none &none &none
                &none      &none        &none        &none        &none &none    &none &none &none &none &none &none
                &none      &none        &none        &none        &none &none    &none &none &none &none &none &none
                &none      &none        &none        &none        &none &none    &none &none &none &none &none &none
                &none      &none        &none        &trans       &none &none    &none &none &trans &none &none &none
            >;
        };
    };
};